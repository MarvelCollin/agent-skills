{
  "version": "1.1",
  "skills": {
    "ux": {
      "cases": [
        {
          "id": "ux-full-audit",
          "input": "/ux https://example.com",
          "expected_sections": [
            "Executive Summary",
            "Scores Breakdown",
            "Critical Issues",
            "Cookie Consent & Privacy",
            "Dark Mode & Theming",
            "Error Pages (404, 500)",
            "Top 3 Quick Wins"
          ],
          "expected_scores": {
            "min_categories_scored": 8,
            "score_range": [1, 10]
          },
          "expected_behavior": [
            "takes_screenshots",
            "navigates_multiple_pages",
            "tests_interactive_elements",
            "identifies_at_least_one_issue",
            "rotates_personas_across_phases",
            "delegates_to_ux_flow_test",
            "delegates_to_ux_accessibility",
            "tests_cookie_consent",
            "tests_404_page",
            "checks_dark_mode",
            "delegates_to_ux_slop",
            "reports_slop_score"
          ]
        },
        {
          "id": "ux-focus-slop",
          "input": "/ux https://example.com slop",
          "expected_behavior": [
            "delegates_to_ux_slop",
            "scans_colors_typography_layout_components",
            "scans_content_for_buzzwords",
            "checks_font_families",
            "produces_slop_score",
            "lists_pattern_ids"
          ]
        },
        {
          "id": "ux-focus-nav",
          "input": "/ux https://example.com nav",
          "expected_sections": [
            "Navigation & IA"
          ],
          "expected_behavior": [
            "deep_dives_navigation",
            "tests_breadcrumbs",
            "tests_search",
            "checks_3_click_rule"
          ]
        },
        {
          "id": "ux-focus-mobile",
          "input": "/ux https://example.com mobile",
          "expected_behavior": [
            "tests_375px_viewport",
            "tests_768px_viewport",
            "checks_touch_targets",
            "checks_horizontal_scroll",
            "uses_aisha_persona"
          ]
        },
        {
          "id": "ux-focus-privacy",
          "input": "/ux https://example.com privacy",
          "expected_behavior": [
            "uses_tom_persona",
            "checks_cookie_banner",
            "checks_reject_all_ease",
            "checks_privacy_policy_link",
            "tests_site_without_cookies"
          ]
        },
        {
          "id": "ux-focus-404",
          "input": "/ux https://example.com 404",
          "expected_behavior": [
            "navigates_to_nonexistent_path",
            "checks_custom_404_page",
            "checks_recovery_options",
            "checks_branding_consistency"
          ]
        }
      ]
    },
    "ux-flow-test": {
      "cases": [
        {
          "id": "flow-test-signup",
          "input": "/ux-flow-test https://example.com \"sign up for an account\"",
          "expected_sections": [
            "Flow Result",
            "Step-by-Step Log",
            "Friction Heatmap",
            "Verdict"
          ],
          "expected_behavior": [
            "records_see_think_do_result_feel",
            "assigns_friction_scores",
            "abandons_if_stuck_5_actions",
            "uses_sarah_persona"
          ]
        },
        {
          "id": "flow-test-purchase",
          "input": "/ux-flow-test https://example.com \"buy a product\"",
          "expected_behavior": [
            "uses_tom_persona",
            "checks_pricing",
            "checks_refund_policy",
            "records_comparison_behavior"
          ]
        },
        {
          "id": "flow-test-abandoned",
          "input": "/ux-flow-test https://httpstat.us/500 \"complete checkout\"",
          "expected_behavior": [
            "declares_flow_abandoned_or_broken",
            "records_blocker",
            "does_not_loop_infinitely"
          ]
        }
      ]
    },
    "ux-accessibility": {
      "cases": [
        {
          "id": "a11y-basic",
          "input": "/ux-accessibility https://example.com",
          "expected_sections": [
            "Accessibility Score",
            "WCAG Compliance Summary",
            "Violations Found",
            "Priority Fixes"
          ],
          "expected_behavior": [
            "checks_alt_text",
            "checks_contrast",
            "checks_keyboard_nav",
            "checks_heading_hierarchy",
            "runs_automated_scan",
            "follows_browser_protocol"
          ]
        },
        {
          "id": "a11y-aaa",
          "input": "/ux-accessibility https://example.com AAA",
          "expected_behavior": [
            "applies_aaa_criteria",
            "stricter_contrast_requirements",
            "checks_sign_language_provisions"
          ]
        }
      ]
    },
    "ux-compare": {
      "cases": [
        {
          "id": "compare-basic",
          "input": "/ux-compare https://github.com https://gitlab.com",
          "expected_sections": [
            "Head-to-Head Summary",
            "Where Site A Wins",
            "Where Site B Wins",
            "Steal-Worthy Ideas",
            "Verdict"
          ],
          "expected_behavior": [
            "visits_both_sites",
            "scores_both_sites",
            "picks_winner_per_category",
            "tests_same_tasks_on_both"
          ]
        }
      ]
    },
    "ux-slop": {
      "cases": [
        {
          "id": "slop-basic",
          "input": "/ux-slop https://example.com",
          "expected_sections": [
            "Slop Score",
            "Pattern Breakdown",
            "Detailed Findings",
            "Biggest AI Tells",
            "De-Slop Recommendations",
            "What's Actually Good"
          ],
          "expected_behavior": [
            "takes_screenshot",
            "fetches_html_source",
            "checks_color_patterns",
            "checks_typography_patterns",
            "checks_layout_patterns",
            "checks_component_patterns",
            "checks_content_buzzwords",
            "checks_motion_patterns",
            "calculates_weighted_score",
            "uses_pattern_ids"
          ]
        },
        {
          "id": "slop-strict",
          "input": "/ux-slop https://example.com strict",
          "expected_behavior": [
            "includes_p2_patterns",
            "stricter_scoring"
          ]
        }
      ]
    },
    "ux-report": {
      "cases": [
        {
          "id": "report-full",
          "input": "/ux-report",
          "expected_sections": [
            "Executive Summary",
            "Scores Breakdown",
            "Cookie Consent & Privacy",
            "Dark Mode & Theming",
            "Error Pages (404, 500)",
            "AI Design Slop Audit",
            "Top 3 Quick Wins",
            "Recommendations"
          ],
          "expected_behavior": [
            "fills_all_template_sections",
            "marks_untested_sections_as_not_tested",
            "calculates_weighted_score",
            "prioritizes_findings",
            "uses_dash_for_untested_scores"
          ]
        }
      ]
    }
  }
}
